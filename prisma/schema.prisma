// Prisma schema for "Na Sua Porta" MVP
// Delivery platform for condominiums

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

// Condominium model (multi-tenant support)
model Condominium {
  id        String   @id @default(cuid())
  name      String
  address   String?
  active    Boolean  @default(true)
  accessCode String? @unique

  // Service configuration
  operatingHours      String?  // e.g. "08:00–22:00"
  maxActiveDeliveries Int?     // max simultaneous active deliveries

  users      User[]
  deliveries Delivery[]
  vendors    Vendor[]
  orders     Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// User model (handles both residents and delivery persons)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  communicationsConsent Boolean @default(false)
  role      UserRole @default(RESIDENT)
  apartment String?  // Only for RESIDENT role (format: "101", "201", etc)
  block     String?  // Only for RESIDENT role (format: "A", "B", etc)
  active    Boolean  @default(true)

  vehicleInfo String? // Only for DELIVERY_PERSON (e.g. "Moto - ABC-1234")
  personalDocument String? // Required for DELIVERY_PERSON (RG/CPF)
  residenceDocument String?
  residentVerificationStatus ResidentVerificationStatus @default(NOT_SUBMITTED)
  registrationSource RegistrationSource @default(DIRECT)

  // Multi-condominium
  condominiumId String?
  condominium   Condominium? @relation(fields: [condominiumId], references: [id])

  // Relations
  createdDeliveries   Delivery[] @relation("CreatedBy")
  acceptedDeliveries  Delivery[] @relation("AcceptedBy")
  createdOrders       Order[]    @relation("OrderCreatedBy")
  orderMessages       OrderMessage[]
  notifications       Notification[]
  vendorProfile       Vendor?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([condominiumId])
}

enum UserRole {
  RESIDENT
  DELIVERY_PERSON
  VENDOR
  CONDOMINIUM_ADMIN
}

enum ResidentVerificationStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum RegistrationSource {
  DIRECT
  CONDOMINIUM_ACCESS_CODE
}

// Delivery model
model Delivery {
  id              String          @id @default(cuid())
  status          DeliveryStatus  @default(REQUESTED)
  type            DeliveryType    @default(PORTARIA)
  
  // Resident info
  residentId      String
  resident        User            @relation("CreatedBy", fields: [residentId], references: [id])
  apartment       String
  block           String
  
  // Delivery person info
  deliveryPersonId String?
  deliveryPerson   User?           @relation("AcceptedBy", fields: [deliveryPersonId], references: [id])

  // Multi-condominium
  condominiumId   String?
  condominium     Condominium?    @relation(fields: [condominiumId], references: [id])

  // Marketplace relation
  orderId         String?         @unique
  order           Order?          @relation(fields: [orderId], references: [id])
  
  // Delivery details
  pickupOrigin    String?  // e.g. "Portaria" or vendor name for marketplace
  description     String?
  notes           String?
  externalPlatform String?  // Platform the resident ordered from (e.g. "iFood", "Amazon")
  externalCode    String?  // Receiving code informed by the resident
  deliveryCode    String?  // Code generated on acceptance, required to mark as DELIVERED
  deliveryCodeGeneratedAt DateTime?
  rating          Int?     // 1-5 stars, set by resident after delivery
  ratingComment   String?  // Optional comment on rating
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  acceptedAt      DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?

  @@index([residentId])
  @@index([deliveryPersonId])
  @@index([status])
  @@index([condominiumId])
  @@index([type])
}

model Vendor {
  id            String     @id @default(cuid())
  name          String
  description   String?
  category      String?    // e.g. "Restaurante", "Mercado", "Farmácia"
  imageUrl      String?
  bannerUrl     String?
  aboutText     String?
  contactPhone  String?
  cnpj          String?
  cnae          String?
  legalRepresentativeDocument String?
  estimatedTimeMinutes Int? @default(30)
  minOrderValue Float?     @default(0)
  rating        Float?     @default(4.5)
  type          VendorType @default(RESIDENT)
  active        Boolean    @default(true)

  condominiumId String?
  condominium   Condominium? @relation(fields: [condominiumId], references: [id])

  userId        String?    @unique
  user          User?      @relation(fields: [userId], references: [id])

  menuItems     MenuItem[]
  orders        Order[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([condominiumId])
  @@index([type])
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  category    String?
  available   Boolean  @default(true)
  imageUrl    String?

  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendorId])
}

model Order {
  id             String        @id @default(cuid())
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)

  customerName   String
  apartment      String
  block          String?
  description    String
  totalAmount    Float         @default(0)
  source         String?  // e.g. "app", "whatsapp"

  vendorId       String?
  vendor         Vendor?       @relation(fields: [vendorId], references: [id])

  condominiumId  String?
  condominium    Condominium?  @relation(fields: [condominiumId], references: [id])

  createdByUserId String?
  createdByUser   User?        @relation("OrderCreatedBy", fields: [createdByUserId], references: [id])

  delivery       Delivery?
  messages       OrderMessage[]

  acceptedAt     DateTime?
  readyAt        DateTime?
  sentAt         DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  cancelledByRole UserRole?
  pickupCode     String?
  pickupCodeGeneratedAt DateTime?
  chatEnabledAt  DateTime?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([condominiumId])
}

enum DeliveryStatus {
  REQUESTED     // Initial state
  ACCEPTED      // Delivery person accepted
  PICKED_UP     // Item picked up from portaria
  DELIVERED     // Delivered to apartment
}

enum DeliveryType {
  PORTARIA
  MARKETPLACE
}

enum VendorType {
  RESIDENT
  EXTERNAL
}

enum OrderStatus {
  PENDING
  ACCEPTED
  READY
  SENT
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum NotificationCategory {
  CHAT_MESSAGE
  ORDER_UPDATE
  DELIVERY_UPDATE
  SYSTEM
}

model OrderMessage {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  content     String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([senderId])
  @@index([expiresAt])
}

model Notification {
  id         String               @id @default(cuid())
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   NotificationCategory
  title      String
  body       String
  link       String?
  orderId    String?
  deliveryId String?
  metadata   String?
  isRead     Boolean              @default(false)
  readAt     DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
  @@index([orderId])
  @@index([deliveryId])
}

// Event log for tracking delivery lifecycle
model DeliveryEvent {
  id          String   @id @default(cuid())
  deliveryId  String
  event       String   // e.g. "CREATED", "ACCEPTED", "PICKED_UP", "DELIVERED"
  userId      String?  // Who triggered the event
  metadata    String?  // JSON string for additional data
  createdAt   DateTime @default(now())

  @@index([deliveryId])
  @@index([event])
  @@index([createdAt])
}
